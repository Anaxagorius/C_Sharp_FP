<UserControl x:Class="StarPublications.Views.SalesOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:StarPublications.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Panel -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="12,12,12,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Search Sales Orders" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,10"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <Label Content="Store ID" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding SearchStoreId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <Label Content="Order Number" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding SearchOrderNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <Label Content="Title ID" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding SearchTitleId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,8,0" VerticalAlignment="Bottom">
                        <Button Content="Search" Command="{Binding SearchCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                        <Button Content="Clear" Command="{Binding ClearSearchCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Content: DataGrid + Edit Form -->
        <Grid Grid.Row="1" Margin="12,6,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6,6,0,0" Padding="12,10">
                        <TextBlock Text="Sales Orders" FontFamily="{StaticResource AppFontFamily}"
                                   FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                    </Border>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Sales}"
                              SelectedItem="{Binding SelectedSale}"
                              Style="{StaticResource AppDataGridStyle}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Store ID" Binding="{Binding StoreId}" Width="80"/>
                            <DataGridTextColumn Header="Order Number" Binding="{Binding OrderNumber}" Width="130"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title.TitleName}" Width="*"/>
                            <DataGridTextColumn Header="Order Date" Binding="{Binding OrderDate, StringFormat='MM/dd/yyyy'}" Width="100"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"/>
                            <DataGridTextColumn Header="Pay Terms" Binding="{Binding PayTerms}" Width="100"/>
                            <DataGridTextColumn Header="Store Name" Binding="{Binding Store.StoreName}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Edit/Add Form Panel -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Margin="6,0,0,0"
                    Visibility="{Binding IsEditOrAdd, Converter={StaticResource BoolToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Add New Sale Order" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,16"
                                   Visibility="{Binding IsAdding, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock Text="Edit Sale Order" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,16"
                                   Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <Label Content="Store ID *" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditStoreId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 IsEnabled="{Binding IsAdding}"
                                 Margin="0,0,0,12"/>

                        <Label Content="Order Number *" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditOrderNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 IsEnabled="{Binding IsAdding}"
                                 Margin="0,0,0,12"/>

                        <Label Content="Title *" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding AvailableTitles}"
                                  SelectedValuePath="TitleId"
                                  SelectedValue="{Binding EditTitleId}"
                                  DisplayMemberPath="TitleName"
                                  Style="{StaticResource AppComboBoxStyle}"
                                  IsEnabled="{Binding IsAdding}"
                                  Margin="0,0,0,12"/>

                        <Label Content="Order Date *" Style="{StaticResource FormLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding EditOrderDate}"
                                    Style="{StaticResource AppDatePickerStyle}"
                                    Margin="0,0,0,12"/>

                        <Label Content="Quantity *" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditQuantity, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 Margin="0,0,0,12"/>

                        <Label Content="Payment Terms" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Text="{Binding EditPayTerms, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Save" Command="{Binding SaveCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="12,6,12,6" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="&#43; Add New" Command="{Binding AddNewCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="&#9998; Edit" Command="{Binding EditCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="&#128465; Delete" Command="{Binding DeleteCommand}"
                        Style="{StaticResource DangerButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="12,6" Margin="12,0,12,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource StatusStyle}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Width="120" IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
