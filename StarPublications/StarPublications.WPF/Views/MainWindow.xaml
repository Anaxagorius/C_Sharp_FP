<Window x:Class="StarPublications.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:StarPublications.Views"
        xmlns:vm="clr-namespace:StarPublications.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Star Publications - Sales Management System"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#9733;" FontSize="28" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Star Publications" FontFamily="{StaticResource AppFontFamily}"
                                   FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Sales Management System" FontFamily="{StaticResource AppFontFamily}"
                                   FontSize="11" Foreground="#B0BEC5"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontFamily="{StaticResource AppFontFamily}" FontSize="12" Foreground="#B0BEC5"
                           Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='dddd, MMMM dd, yyyy', Mode=OneTime}"/>
            </Grid>
        </Border>

        <!-- Main Content - Tab Control -->
        <TabControl Grid.Row="1" Style="{StaticResource AppTabControlStyle}"
                    Margin="0" Background="{StaticResource BackgroundBrush}">

            <TabItem Header="&#128203;  Sales Orders" Style="{StaticResource AppTabItemStyle}">
                <views:SalesOrderView DataContext="{Binding SalesOrderViewModel}"/>
            </TabItem>

            <TabItem Header="&#128218;  Books" Style="{StaticResource AppTabItemStyle}">
                <views:BookSearchView DataContext="{Binding BookSearchViewModel}"/>
            </TabItem>

            <TabItem Header="&#127970;  Publishers" Style="{StaticResource AppTabItemStyle}">
                <views:PublisherSearchView DataContext="{Binding PublisherSearchViewModel}"/>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource PrimaryBrush}">
            <TextBlock Text="Star Publications v1.0  |  Connected to PUBs Database"
                       FontFamily="{StaticResource AppFontFamily}"
                       FontSize="11" Foreground="#B0BEC5"
                       VerticalAlignment="Center"
                       Margin="16,0"/>
        </Border>
    </Grid>
</Window>
