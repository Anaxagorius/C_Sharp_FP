<UserControl x:Class="StarPublications.Views.BookSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:StarPublications.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Panel -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="12,12,12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Label Content="Search Books (by title, type, publisher, or author)" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,8,0">
                    <Button Content="Search" Command="{Binding SearchCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                    <Button Content="Clear" Command="{Binding ClearCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Books DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="12,6,12,6" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6,6,0,0" Padding="12,10">
                    <TextBlock Text="Books Catalog" FontFamily="{StaticResource AppFontFamily}"
                               FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                </Border>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Books}"
                          SelectedItem="{Binding SelectedBook}"
                          Style="{StaticResource AppDataGridStyle}"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Title ID" Binding="{Binding TitleId}" Width="80"/>
                        <DataGridTextColumn Header="Title" Binding="{Binding TitleName}" Width="*"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                        <DataGridTextColumn Header="Price" Binding="{Binding DisplayPrice}" Width="80"/>
                        <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher.PublisherName}" Width="150"/>
                        <DataGridTextColumn Header="Authors" Binding="{Binding AuthorNames}" Width="180"/>
                        <DataGridTextColumn Header="YTD Sales" Binding="{Binding YtdSales}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Book Detail Panel -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="12,6,12,6"
                Visibility="{Binding SelectedBook, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Book Details" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Title ID: " FontWeight="SemiBold" Style="{StaticResource BaseTextStyle}" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedBook.TitleId}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Publisher: " FontWeight="SemiBold" Style="{StaticResource BaseTextStyle}" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedBook.Publisher.PublisherName}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Authors: " FontWeight="SemiBold" Style="{StaticResource BaseTextStyle}" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedBook.AuthorNames}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Published: " FontWeight="SemiBold" Style="{StaticResource BaseTextStyle}" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedBook.PubDate, StringFormat='MM/dd/yyyy'}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Notes: " FontWeight="SemiBold" Style="{StaticResource BaseTextStyle}" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedBook.Notes}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <TextBlock Text="Available At Stores" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,10"/>
                    <DataGrid ItemsSource="{Binding StoresWithBook}"
                              Style="{StaticResource AppDataGridStyle}"
                              MaxHeight="150"
                              BorderThickness="1"
                              BorderBrush="#E0E0E0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Store" Binding="{Binding StoreName}" Width="*"/>
                            <DataGridTextColumn Header="City" Binding="{Binding City}" Width="100"/>
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Text="No store availability data found."
                               Style="{StaticResource StatusStyle}"
                               Margin="0,4,0,0"
                               Visibility="{Binding StoresWithBook.Count, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="12,6" Margin="12,0,12,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource StatusStyle}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Width="120" IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
