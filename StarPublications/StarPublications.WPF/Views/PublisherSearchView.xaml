<UserControl x:Class="StarPublications.Views.PublisherSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:StarPublications.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Panel -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="12,12,12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Label Content="Search Publishers (by name, city, state, or country)" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,8,0">
                    <Button Content="Search" Command="{Binding SearchCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                    <Button Content="Clear" Command="{Binding ClearCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Publishers DataGrid -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="12,6,12,6" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="6,6,0,0" Padding="12,10">
                    <TextBlock Text="Publishers" FontFamily="{StaticResource AppFontFamily}"
                               FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                </Border>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Publishers}"
                          SelectedItem="{Binding SelectedPublisher}"
                          Style="{StaticResource AppDataGridStyle}"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Publisher ID" Binding="{Binding PubId}" Width="100"/>
                        <DataGridTextColumn Header="Publisher Name" Binding="{Binding PublisherName}" Width="*"/>
                        <DataGridTextColumn Header="City" Binding="{Binding City}" Width="120"/>
                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="70"/>
                        <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="120"/>
                        <DataGridTextColumn Header="Books" Binding="{Binding Titles.Count}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Publisher Detail and Books Panel -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="12,6,12,6"
                Visibility="{Binding IsPublisherSelected, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Publisher Info -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0" MinWidth="200">
                    <TextBlock Text="Publisher Details" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID: " FontWeight="SemiBold" Style="{StaticResource BaseTextStyle}" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPublisher.PubId}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name: " FontWeight="SemiBold" Style="{StaticResource BaseTextStyle}" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPublisher.PublisherName}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="City: " FontWeight="SemiBold" Style="{StaticResource BaseTextStyle}" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedPublisher.City}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="State: " FontWeight="SemiBold" Style="{StaticResource BaseTextStyle}" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedPublisher.State}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Country: " FontWeight="SemiBold" Style="{StaticResource BaseTextStyle}" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedPublisher.Country}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,4"/>
                    </Grid>
                </StackPanel>

                <!-- Books by Publisher -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Books by this Publisher" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,10"/>
                    <DataGrid ItemsSource="{Binding SelectedPublisher.Titles}"
                              Style="{StaticResource AppDataGridStyle}"
                              MaxHeight="180"
                              BorderThickness="1"
                              BorderBrush="#E0E0E0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title ID" Binding="{Binding TitleId}" Width="80"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding TitleName}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding DisplayPrice}" Width="80"/>
                            <DataGridTextColumn Header="YTD Sales" Binding="{Binding YtdSales}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="12,6" Margin="12,0,12,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource StatusStyle}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Width="120" IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
